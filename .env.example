# Внутри контейнера Caddy слушает :80. На хост пробрасывается как host:container → значение ниже + ":80".
# Безопасный дефолт (не трогает системный nginx на 80/443): только localhost.
# CADDY_PUBLISH=127.0.0.1:9080

# Только отдельная VM/дроплет целиком под этот сайт, на 80/443 никто больше не слушает:
# CADDY_PUBLISH=0.0.0.0:80

# Сайт в Caddyfile. За nginx — обычно HTTP внутри, без ACME в Caddy:
DOMAIN=:80

# Список Origin для CORS у FastAPI (через запятую). Пусто — встроенный список по умолчанию.
# CORS_ORIGINS=https://electoral-calc.org,http://127.0.0.1:9080

# Опционально: Google Analytics 4 (бесплатный GA4). Подставляется при docker compose build.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Кэш CSV/DuckDB для справочника ParlGov (в контейнере backend по умолчанию /app/data/parlgov).
# PARLGOV_DATA_DIR=/app/data/parlgov
