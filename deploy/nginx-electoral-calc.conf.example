# Пример для системного nginx на дроплете, где 80/443 уже заняты.
# Не включать автоматически: скопируйте в sites-available, проверьте nginx -t, затем reload.
#
# upstream — порт из docker-compose (дефолт 127.0.0.1:9080).

upstream electoral_calc_caddy {
    server 127.0.0.1:9080;
    keepalive 8;
}

server {
    listen 80;
    listen [::]:80;
    server_name electoral-calc.org www.electoral-calc.org;

    location / {
        proxy_pass http://electoral_calc_caddy;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# После certbot для этого server_name добавится блок listen 443 ssl; …
